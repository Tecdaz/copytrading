# Google Sheets OAuth2 credentials
# Download from Google Cloud Console > APIs & Services > Credentials
GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/client_secret.json

# Google Sheets ID (from the URL of your spreadsheet)
GOOGLE_SHEET_ID=1NKYMZXTPaR41sEtxzbs3i_igPh6BXNH9GBEKX9OOWAI

# Path to cached OAuth token (for headless/server environments)
# On first run, this file is created after browser-based auth.
# On subsequent runs, this file is used to refresh the token without a browser.
# Copy the pre-authenticated token from your local machine to the server.
GOOGLE_TOKEN_PATH=.google_token.json
